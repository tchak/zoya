pub enum Number { Int(Int), Float(Float) }

pub enum JSON {
    Null,
    Bool(Bool),
    Number(Number),
    String(String),
    Array(List<JSON>),
    Object(List<(String, JSON)>),
}

pub enum ParseError { ParseError }

#[builtin]
pub fn parse(value: String) -> root::result::Result<JSON, ParseError> ()
