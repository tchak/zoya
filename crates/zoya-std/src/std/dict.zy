use super::option::Option

impl<K, V> Dict<K, V> {
    #[builtin] pub fn new() -> Self ()
    #[builtin] pub fn get(self, key: K) -> Option<V> ()
    #[builtin] pub fn insert(self, key: K, value: V) -> Self ()
    #[builtin] pub fn remove(self, key: K) -> Self ()
    #[builtin] pub fn keys(self) -> List<K> ()
    #[builtin] pub fn values(self) -> List<V> ()
    #[builtin] pub fn len(self) -> Int ()
    pub fn is_empty(self) -> Bool { self.len() == 0 }
}
