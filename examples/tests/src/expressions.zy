#[test]
fn test_int_literal() -> () assert_eq(42, 42)

#[test]
fn test_arithmetic() -> () assert_eq(1 + 2 * 3, 7)

#[test]
fn test_float_literal() -> () assert_eq(3.15, 3.15)

#[test]
fn test_bool_true() -> () assert(true)

#[test]
fn test_bool_false() -> () assert_eq(false, false)

#[test]
fn test_equality_true() -> () assert(1 == 1)

#[test]
fn test_equality_false() -> () assert(1 == 2 == false)

#[test]
fn test_inequality() -> () assert(1 != 2)

#[test]
fn test_less_than() -> () assert(1 < 2)

#[test]
fn test_greater_than() -> () assert(2 > 1)

#[test]
fn test_less_equal() -> () assert(2 <= 2)

#[test]
fn test_greater_equal() -> () assert(2 >= 2)

#[test]
fn test_bool_equality() -> () assert(true == false == false)

#[test]
fn test_float_comparison() -> () assert(1.5 < 2.5)

#[test]
fn test_comparison_with_arithmetic() -> () assert(1 + 2 == 3)

#[test]
fn test_chained_method_calls() -> () assert_eq("hello".to_uppercase().len(), 5)

fn get_length(s: String) -> Int { s.len() }

#[test]
fn test_method_call_in_function() -> () assert_eq(get_length("hello"), 5)

#[test]
fn test_match_with_commas() -> () {
  assert_eq(match 1 { 0 => 0, 1 => 10, _ => 100 }, 10)
}

#[test]
fn test_match_braced_simple() -> () {
  assert_eq(match 1 { 0 => { 0 }, 1 => { 10 }, _ => { 100 } }, 10)
}

#[test]
fn test_match_braced_block() -> () {
  let result = match 5 {
    n => {
      let doubled = n * 2;
      doubled + 1
    }
  };
  assert_eq(result, 11)
}

#[test]
fn test_match_block_multiple_bindings() -> () {
  let result = match 3 {
    n => {
      let a = n * 2;
      let b = a + 1;
      let c = b * 2;
      c
    }
  };
  assert_eq(result, 14)
}

#[test]
fn test_match_block_pattern_binding_visible() -> () {
  let result = match 10 {
    x => {
      let y = x + 5;
      x + y
    }
  };
  assert_eq(result, 25)
}

#[test]
fn test_match_mixed_arms() -> () {
  let result = match 2 {
    0 => 100,
    1 => { let x = 1; x * 10 },
    n => {
      let base = n * 10;
      base + n
    }
  };
  assert_eq(result, 22)
}

#[test]
fn test_assert_true() -> () {
  let unused =assert(true);
  assert_eq(1, 1)
}

#[test]
fn test_assert_eq_same_values() -> () {
  let unused =assert_eq(1, 1);
  assert_eq("hello", "hello")
}

#[test]
fn test_assert_ne_different_values() -> () {
  let unused =assert_ne(1, 2);
  assert_ne("hello", "world")
}

#[test]
fn test_assert_eq_deep_equality_lists() -> () assert_eq([1, 2, 3], [1, 2, 3])

#[test]
fn test_arithmetic_lambda_inference() -> () {
  let add = |x, y| x + y;
  assert_eq(add(10, 32), 42)
}

#[test]
fn test_ordering_lambda_inference() -> () {
  let lt = |x, y| x < y;
  assert(lt(1, 2))
}

#[test]
fn test_negation_lambda_inference() -> () {
  let neg = |x| -x;
  assert_eq(neg(42), -42)
}
