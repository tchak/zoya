mod math
mod types
mod geom
mod parent
mod reexport_types
pub mod test_enum_variants
pub mod test_reexported_variants

use self::math::*
use self::types::*
use self::geom::*
use self::parent::*

#[test]
fn test_glob_import_functions() -> () assert_eq(add(1, mul(2, 3)), 7)

#[test]
fn test_glob_import_enum() -> () {
  assert_eq(match Color::Red { Color::Red => 1, Color::Green => 2, Color::Blue => 3 }, 1)
}

#[test]
fn test_glob_import_struct() -> () {
  let p = Point { x: 3, y: 4 };
  assert_eq(p.x + p.y, 7)
}

#[test]
fn test_glob_import_includes_modules() -> () assert_eq(child::helper(), 42)
