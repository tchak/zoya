mod utils

use self::utils::x
use self::utils::foo
use self::utils::helper
use self::utils::add

fn foo() -> Bool { true }
fn helper() -> Int { 1 }

#[test]
fn test_local_shadows_import() -> () {
  let x = true;
  assert(x)
}

#[test]
fn test_import_shadows_module_level() -> () assert_eq(foo(), 42)

#[test]
fn test_qualified_path_bypasses_import() -> () {
  let a = helper();
  let b = self::helper();
  assert_eq(a + b, 101)
}

#[test]
fn test_multiple_paths_same_function() -> () {
  let a = add(1, 2);
  let b = utils::add(3, 4);
  let c = root::modules::shadowing::utils::add(5, 6);
  assert_eq(a + b + c, 21)
}
