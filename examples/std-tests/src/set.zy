#[test]
fn test_new_is_empty() -> () {
  let s: Set<Int> = Set::new();
  let _ = assert_eq(s.is_empty(), true);
  assert_eq(s.len(), 0)
}

#[test]
fn test_insert_and_contains() -> () {
  assert_eq(Set::new().insert(1).insert(2).insert(3).contains(2), true)
}

#[test]
fn test_contains_missing() -> () {
  assert_eq(Set::new().insert(1).insert(2).contains(3), false)
}

#[test]
fn test_len() -> () {
  assert_eq(Set::new().insert(1).insert(2).insert(3).len(), 3)
}

#[test]
fn test_insert_duplicate() -> () {
  assert_eq(Set::new().insert(1).insert(1).insert(1).len(), 1)
}

#[test]
fn test_remove() -> () {
  assert_eq(Set::new().insert(1).insert(2).remove(1).contains(1), false)
}

#[test]
fn test_remove_len() -> () {
  assert_eq(Set::new().insert(1).insert(2).insert(3).remove(2).len(), 2)
}

#[test]
fn test_from() -> () {
  assert_eq(Set::from([1, 2, 3, 2, 1]).len(), 3)
}

#[test]
fn test_to_list() -> () {
  assert_eq(Set::from([1, 2, 3]).to_list().len(), 3)
}

#[test]
fn test_union() -> () {
  assert_eq(Set::from([1, 2, 3]).union(Set::from([3, 4, 5])).len(), 5)
}

#[test]
fn test_intersection() -> () {
  assert_eq(Set::from([1, 2, 3]).intersection(Set::from([2, 3, 4])).len(), 2)
}

#[test]
fn test_difference() -> () {
  let d = Set::from([1, 2, 3]).difference(Set::from([2, 3, 4]));
  let _ = assert_eq(d.len(), 1);
  assert_eq(d.contains(1), true)
}

#[test]
fn test_is_subset() -> () {
  let _ = assert_eq(Set::from([1, 2]).is_subset(Set::from([1, 2, 3])), true);
  assert_eq(Set::from([1, 2, 4]).is_subset(Set::from([1, 2, 3])), false)
}

#[test]
fn test_is_superset() -> () {
  assert_eq(Set::from([1, 2, 3]).is_superset(Set::from([1, 2])), true)
}

#[test]
fn test_is_disjoint() -> () {
  let _ = assert_eq(Set::from([1, 2]).is_disjoint(Set::from([3, 4])), true);
  assert_eq(Set::from([1, 2]).is_disjoint(Set::from([2, 3])), false)
}

#[test]
fn test_equality() -> () {
  assert_eq(Set::from([1, 2, 3]) == Set::from([3, 2, 1]), true)
}

#[test]
fn test_inequality() -> () {
  assert_eq(Set::from([1, 2]) != Set::from([1, 3]), true)
}

#[test]
fn test_string_elements() -> () {
  let s = Set::new().insert("hello").insert("world");
  let _ = assert_eq(s.contains("hello"), true);
  assert_eq(s.contains("foo"), false)
}
