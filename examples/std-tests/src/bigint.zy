#[test]
fn test_addition() -> () assert_eq(1n + 2n, 3n)

#[test]
fn test_abs() -> () assert_eq((-42n).abs(), 42n)

#[test]
fn test_to_string() -> () assert_eq(42n.to_string(), "42")

#[test]
fn test_pow() -> () assert_eq(2n.pow(10n), 1024n)

#[test]
fn test_clamp() -> () assert_eq(15n.clamp(0n, 10n), 10n)

#[test]
fn test_signum() -> () {
  let _ = assert_eq((-42n).signum(), -1n);
  assert_eq(0n.signum(), 0n)
}

#[test]
fn test_is_positive() -> () assert_eq(5n.is_positive(), true)

#[test]
fn test_is_negative() -> () assert_eq((-3n).is_negative(), true)

#[test]
fn test_is_zero() -> () assert_eq(0n.is_zero(), true)

#[test]
fn test_to_int() -> () assert_eq(42n.to_int(), 42)
