#[test]
fn test_len() -> () {
  let _ = assert_eq([1, 2, 3].len(), 3);
  assert_eq([].len(), 0)
}

#[test]
fn test_is_empty() -> () {
  let _ = assert_eq([].is_empty(), true);
  assert_eq([1, 2].is_empty(), false)
}

#[test]
fn test_reverse() -> () {
  let _ = assert_eq([1, 2, 3].reverse(), [3, 2, 1]);
  let xs: List<Int> = [];
  assert_eq(xs.reverse(), [])
}

#[test]
fn test_push() -> () {
  let _ = assert_eq([1, 2].push(3), [1, 2, 3]);
  let _ = assert_eq([].push(1), [1]);
  assert_eq([1, 2].push(3).reverse(), [3, 2, 1])
}

#[test]
fn test_map() -> () {
  let _ = assert_eq([1, 2, 3].map(|x| x * 2), [2, 4, 6]);
  assert_eq([].map(|x: Int| x * 2), [])
}

#[test]
fn test_map_type_change() -> () {
  assert_eq([1, 2].map(|x| x > 0), [true, true])
}

#[test]
fn test_filter() -> () {
  let _ = assert_eq([1, 2, 3, 4].filter(|x| x > 2), [3, 4]);
  assert_eq([1, 2, 3].filter(|x| x > 10), [])
}

#[test]
fn test_fold() -> () {
  let _ = assert_eq([1, 2, 3].fold(0, |acc, x| acc + x), 6);
  assert_eq([].fold(0, |acc: Int, x: Int| acc + x), 0)
}

#[test]
fn test_filter_map() -> () {
  assert_eq([1, 2, 3].filter_map(|x| match x > 1 {
    true => Some(x * 2),
    false => None,
  }), [4, 6])
}

#[test]
fn test_first() -> () {
  let _ = assert_eq([10, 20, 30].first(), Some(10));
  let xs: List<Int> = [];
  assert_eq(xs.first(), None)
}

#[test]
fn test_last() -> () {
  let _ = assert_eq([10, 20, 30].last(), Some(30));
  let xs: List<Int> = [];
  assert_eq(xs.last(), None)
}

#[test]
fn test_truncate() -> () assert_eq([1, 2, 3, 4].truncate(2), [1, 2])

#[test]
fn test_insert() -> () assert_eq([1, 3].insert(1, 2), [1, 2, 3])

#[test]
fn test_remove() -> () assert_eq([1, 2, 3].remove(1), [1, 3])

#[test]
fn test_chained() -> () {
  assert_eq([1, 2, 3].filter(|x| x > 1).map(|x| x * 10), [20, 30])
}
