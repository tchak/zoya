{
  "grammars": [
    {
      "name": "zoya",
      "camelcase": "Zoya",
      "scope": "source.zoya",
      "path": ".",
      "file-types": [
        "zy"
      ],
      "highlights": "queries/highlights.scm",
      "locals": "queries/locals.scm"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for the Zoya programming language",
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-zoya"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
